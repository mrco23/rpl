generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id_admin         Int               @id @default(autoincrement())
  username         String?           @unique
  password         String
  berita           Berita[]
  ekstrakurikuler  Ekstrakurikuler[]
  fasilitas        Fasilitas[]
  kontak           Kontak[]
  pengumuman       Pengumuman[]
  prestasi         Prestasi[]
  profil           Profil[]
  program_unggulan ProgramUnggulan[]

  @@map("admin")
}

model Alamat {
  id_alamat      Int       @id @default(autoincrement())
  provinsi       String
  kota_kabupaten String
  kecamatan      String
  kelurahan      String
  rt_rw          String
  kode_pos       String
  id_pendaftar   Int       @unique
  pendaftar      Pendaftar @relation(fields: [id_pendaftar], references: [id_pendaftar], onDelete: Cascade)

  @@map("alamat")
}

model Berita {
  id_berita      Int      @id @default(autoincrement())
  judul_berita   String
  deskripsi      String   @db.Text
  gambar_berita  String?
  tanggal_dibuat DateTime @default(now())
  id_admin       Int
  admin          Admin    @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("berita")
}

model Dokumen {
  id_dokumen     Int          @id @default(autoincrement())
  nama_dokumen   String
  jenis_dokumen  String
  id_pendaftar   Int
  id_verifikator Int?
  pendaftar      Pendaftar    @relation(fields: [id_pendaftar], references: [id_pendaftar], onDelete: Cascade)
  verifikator    Verifikator? @relation(fields: [id_verifikator], references: [id_verifikator])

  @@unique([id_pendaftar, nama_dokumen], map: "dokumen_unique")
  @@index([id_pendaftar])
  @@index([id_verifikator])
  @@map("dokumen")
}

model Ekstrakurikuler {
  id_ekstrakurikuler Int     @id @default(autoincrement())
  nama_ekskul        String
  p_jwb_ekskul       String
  gambar_ekskul      String?
  deskripsi          String  @db.Text
  id_admin           Int
  admin              Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("ekstrakurikuler")
}

model Fasilitas {
  id_fasilitas     Int     @id @default(autoincrement())
  nama_fasilitas   String
  deskripsi        String  @db.Text
  gambar_fasilitas String?
  id_admin         Int
  admin            Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("fasilitas")
}

model Gelombang {
  id_gelombang    Int         @id @default(autoincrement())
  nama            String
  tanggal_mulai   DateTime
  tanggal_selesai DateTime
  kuota           Int
  pendaftar       Pendaftar[]

  @@map("gelombang")
}

model Kontak {
  id_kontak Int     @id @default(autoincrement())
  no_telpon String
  instagram String
  tiktok    String
  facebook  String
  youtube   String
  email     String
  whatsapp  String?
  id_admin  Int
  admin     Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("kontak")
}

model Pendaftar {
  id_pendaftar         Int                    @id @default(autoincrement())
  nama_lengkap         String
  kata_sandi           String?
  nisn                 String?                @unique
  tempat_lahir         String?
  tanggal_lahir        DateTime?              @db.Date
  jenis_kelamin        String
  no_hp                String
  asal_sekolah         String
  email                String                 @unique(map: "email")
  nama_wali            String?
  status_pendaftaran   String                 @default("menunggu verifikasi")
  catatan_dokumen      String?                @db.Text
  tanggal_daftar       DateTime               @default(now())
  id_gelombang         Int?
  id_verifikator       Int?
  resetPasswordToken   String?                @unique
  resetPasswordExpires DateTime?              @db.DateTime(0)
  alamat               Alamat?
  dokumen              Dokumen[]
  gelombang            Gelombang?             @relation(fields: [id_gelombang], references: [id_gelombang])
  verifikator          Verifikator?           @relation(fields: [id_verifikator], references: [id_verifikator])
  pengumuman_pendaftar PengumumanPendaftar[]

  @@index([id_gelombang], map: "pendaftar_id_gelombang_fkey")
  @@index([id_verifikator])
  @@index([status_pendaftaran], map: "pendaftar_status_idx")
  @@map("pendaftar")
}

model Pengumuman {
  id_pengumuman        Int                    @id @default(autoincrement())
  judul_pengumuman     String
  deksripsi            String?                @db.Text
  tanggal_dibuat       DateTime               @default(now())
  id_admin             Int
  admin                Admin                  @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)
  pengumuman_pendaftar PengumumanPendaftar[]

  @@index([id_admin])
  @@map("pengumuman")
}

model PengumumanPendaftar {
  id_pengumuman_pendaftar Int        @id @default(autoincrement())
  id_pendaftar            Int
  id_pengumuman           Int
  pendaftar               Pendaftar  @relation(fields: [id_pendaftar], references: [id_pendaftar], onDelete: Cascade)
  pengumuman              Pengumuman @relation(fields: [id_pengumuman], references: [id_pengumuman], onDelete: Cascade)

  @@index([id_pendaftar])
  @@index([id_pengumuman])
  @@map("pengumuman_pendaftar")
}

model Prestasi {
  id_prestasi     Int     @id @default(autoincrement())
  judul_prestasi  String
  deskripsi       String  @db.Text
  peraih_prestasi String
  gambar_prestasi String?
  id_admin        Int
  admin           Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("prestasi")
}

model Profil {
  id_profil           Int    @id @default(autoincrement())
  nama_sekolah        String @unique
  visi                String @db.Text
  misi                String @db.Text
  nama_kepala_sekolah String
  foto_kepala_sekolah String
  kata_sambutan       String @db.Text
  id_admin            Int
  akreditasi          String @db.Char(1)
  nomor_sk_akreditasi String
  admin               Admin  @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("profil")
}

model ProgramUnggulan {
  id_program Int     @id @default(autoincrement())
  nama_pu    String
  deskripsi  String  @db.Text
  gambar_pu  String?
  id_admin   Int
  admin      Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("program_unggulan")
}

model Verifikator {
  id_verifikator Int         @id @default(autoincrement())
  username       String      @unique
  password       String
  nama           String
  dokumen        Dokumen[]
  pendaftar      Pendaftar[]

  @@map("verifikator")
}
