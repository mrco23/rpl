generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id_admin         Int               @id @default(autoincrement())
  username         String?           @unique @db.VarChar(100)
  password         String            @db.VarChar(255)
  status_aktif     Boolean           @default(true)
  berita           Berita[]
  ekstrakurikuler  Ekstrakurikuler[]
  fasilitas        Fasilitas[]
  kontak           Kontak[]
  pengumuman       Pengumuman[]
  prestasi         Prestasi[]
  profil           Profil[]
  program_unggulan ProgramUnggulan[]

  @@map("admin")
}

model Alamat {
  id_alamat      Int       @id @default(autoincrement())
  provinsi       String    @db.VarChar(100)
  kota_kabupaten String    @db.VarChar(100)
  kecamatan      String    @db.VarChar(100)
  kelurahan      String    @db.VarChar(100)
  rt_rw          String    @db.VarChar(50)
  kode_pos       String    @db.VarChar(10)
  id_pendaftar   Int       @unique
  pendaftar      Pendaftar @relation(fields: [id_pendaftar], references: [id_pendaftar], onDelete: Cascade)

  @@map("alamat")
}

model Berita {
  id_berita      Int      @id @default(autoincrement())
  judul_berita   String   @db.VarChar(200)
  deskripsi      String   @db.Text
  gambar_berita  String?  @db.VarChar(250)
  tanggal_dibuat DateTime @default(now()) @db.DateTime(3)
  id_admin       Int
  admin          Admin    @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("berita")
}

model Dokumen {
  id_dokumen     Int          @id @default(autoincrement())
  nama_dokumen   String       @db.VarChar(150)
  jenis_dokumen  String       @db.VarChar(100)
  id_pendaftar   Int
  id_verifikator Int?
  pendaftar      Pendaftar    @relation(fields: [id_pendaftar], references: [id_pendaftar], onDelete: Cascade)
  verifikator    Verifikator? @relation(fields: [id_verifikator], references: [id_verifikator])

  @@unique([id_pendaftar, nama_dokumen], map: "dokumen_unique")
  @@index([id_pendaftar])
  @@index([id_verifikator])
  @@map("dokumen")
}

model Ekstrakurikuler {
  id_ekstrakurikuler Int     @id @default(autoincrement())
  nama_ekskul        String  @db.VarChar(100)
  p_jwb_ekskul       String  @db.VarChar(150)
  gambar_ekskul      String? @db.VarChar(250)
  deskripsi          String  @db.Text
  id_admin           Int
  admin              Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("ekstrakurikuler")
}

model Fasilitas {
  id_fasilitas     Int     @id @default(autoincrement())
  nama_fasilitas   String  @db.VarChar(100)
  deskripsi        String  @db.Text
  gambar_fasilitas String? @db.VarChar(250)
  id_admin         Int
  admin            Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("fasilitas")
}

model Gelombang {
  id_gelombang    Int         @id @default(autoincrement())
  nama            String      @db.VarChar(100)
  tanggal_mulai   DateTime    @db.DateTime(3)
  tanggal_selesai DateTime    @db.DateTime(3)
  kuota           Int
  status_validasi String      @default("belum_diajukan") @db.VarChar(50)
  tanggal_validasi DateTime?  @db.DateTime(3)
  pendaftar       Pendaftar[]

  @@map("gelombang")
}

model Kontak {
  id_kontak Int     @id @default(autoincrement())
  no_telpon String  @db.VarChar(20)
  instagram String  @db.VarChar(100)
  tiktok    String  @db.VarChar(100)
  facebook  String  @db.VarChar(100)
  youtube   String  @db.VarChar(100)
  email     String  @db.VarChar(100)
  whatsapp  String? @db.VarChar(20)
  id_admin  Int
  admin     Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("kontak")
}

model Pendaftar {
  id_pendaftar         Int                   @id @default(autoincrement())
  nama_lengkap         String                @db.VarChar(150)
  kata_sandi           String?               @db.VarChar(255)
  nisn                 String?               @unique @db.VarChar(20)
  tempat_lahir         String?               @db.VarChar(100)
  tanggal_lahir        DateTime?             @db.Date
  jenis_kelamin        String                @db.VarChar(20)
  no_hp                String                @db.VarChar(20)
  asal_sekolah         String                @db.VarChar(150)
  email                String                @unique(map: "email") @db.VarChar(100)
  nama_wali            String?               @db.VarChar(150)
  status_pendaftaran   String                @default("menunggu verifikasi") @db.VarChar(50)
  catatan_dokumen      String?               @db.Text
  tanggal_daftar       DateTime              @default(now()) @db.DateTime(3)
  id_gelombang         Int?
  id_verifikator       Int?
  resetPasswordToken   String?               @unique @db.VarChar(255)
  resetPasswordExpires DateTime?             @db.DateTime(0)
  alamat               Alamat?
  dokumen              Dokumen[]
  gelombang            Gelombang?            @relation(fields: [id_gelombang], references: [id_gelombang])
  verifikator          Verifikator?          @relation(fields: [id_verifikator], references: [id_verifikator])
  pengumuman_pendaftar PengumumanPendaftar[]

  @@index([id_gelombang], map: "pendaftar_id_gelombang_fkey")
  @@index([id_verifikator])
  @@index([status_pendaftaran], map: "pendaftar_status_idx")
  @@map("pendaftar")
}

model Pengumuman {
  id_pengumuman        Int                   @id @default(autoincrement())
  judul_pengumuman     String                @db.VarChar(200)
  deksripsi            String?               @db.Text
  tanggal_dibuat       DateTime              @default(now()) @db.DateTime(3)
  id_admin             Int
  admin                Admin                 @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)
  pengumuman_pendaftar PengumumanPendaftar[]

  @@index([id_admin])
  @@map("pengumuman")
}

model PengumumanPendaftar {
  id_pengumuman_pendaftar Int        @id @default(autoincrement())
  id_pendaftar            Int
  id_pengumuman           Int
  pendaftar               Pendaftar  @relation(fields: [id_pendaftar], references: [id_pendaftar], onDelete: Cascade)
  pengumuman              Pengumuman @relation(fields: [id_pengumuman], references: [id_pengumuman], onDelete: Cascade)

  @@index([id_pendaftar])
  @@index([id_pengumuman])
  @@map("pengumuman_pendaftar")
}

model Prestasi {
  id_prestasi     Int     @id @default(autoincrement())
  judul_prestasi  String  @db.VarChar(200)
  deskripsi       String  @db.Text
  peraih_prestasi String  @db.VarChar(150)
  gambar_prestasi String? @db.VarChar(250)
  id_admin        Int
  admin           Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("prestasi")
}

model Profil {
  id_profil           Int    @id @default(autoincrement())
  nama_sekolah        String @unique @db.VarChar(150)
  visi                String @db.Text
  misi                String @db.Text
  nama_kepala_sekolah String @db.VarChar(150)
  foto_kepala_sekolah String @db.VarChar(250)
  kata_sambutan       String @db.Text
  id_admin            Int
  akreditasi          String @db.Char(1)
  nomor_sk_akreditasi String @db.VarChar(100)
  admin               Admin  @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("profil")
}

model ProgramUnggulan {
  id_program Int     @id @default(autoincrement())
  nama_pu    String  @db.VarChar(150)
  deskripsi  String  @db.Text
  gambar_pu  String? @db.VarChar(250)
  id_admin   Int
  admin      Admin   @relation(fields: [id_admin], references: [id_admin], onDelete: Cascade)

  @@index([id_admin])
  @@map("program_unggulan")
}

model Verifikator {
  id_verifikator Int         @id @default(autoincrement())
  username       String      @unique @db.VarChar(100)
  password       String      @db.VarChar(255)
  nama           String      @db.VarChar(150)
  status_aktif   Boolean     @default(true)
  dokumen        Dokumen[]
  pendaftar      Pendaftar[]

  @@map("verifikator")
}

model KepalaSekolah {
  id_kepala_sekolah Int      @id @default(autoincrement())
  username          String   @unique @db.VarChar(50)
  password          String   @db.VarChar(255)
  nama              String   @db.VarChar(100)
  status_aktif      Boolean  @default(true)
  created_at        DateTime @default(now()) @db.DateTime(3)
  updated_at        DateTime @updatedAt @db.DateTime(3)

  @@map("kepala_sekolah")
}
