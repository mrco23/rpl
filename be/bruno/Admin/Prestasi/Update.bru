meta {
  name: Update
  type: http
  seq: 1
}

put {
  url: {{base_url}}/prestasi/1
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  judul_prestasi: Juara 1 Lomba Web
  deskripsi: Tingkat Nasional
  peraih_prestasi: Tim Sukses
  gambar_prestasi: @file(path/to/image.jpg)
}
