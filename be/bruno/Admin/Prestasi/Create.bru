meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/prestasi
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  judul_prestasi: Juara Olimpiade Matematika
  deskripsi: Tingkat Nasional 2026
  peraih_prestasi: Budi Santoso
  gambar_prestasi: @file(path/to/mock/image.jpg)
}
