meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/fasilitas
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_fasilitas: Perpustakaan Modern
  deskripsi: Ratusan buku tersedia
  gambar_fasilitas: @file(path/to/mock/image.jpg)
}
