meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/fasilitas
  body: multiFormData
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_fasilitas: Ruang Multimedia
  deskripsi: Ruang multimedia modern dengan perlengkapan audio visual.
  gambar: @file()
}
