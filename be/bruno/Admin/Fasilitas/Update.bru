meta {
  name: Update
  type: http
  seq: 1
}

put {
  url: {{base_url}}/fasilitas/1
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_fasilitas: Fasilitas Utama
  deskripsi: Fasilitas yang memadai
  gambar_fasilitas: @file(path/to/image.jpg)
}
