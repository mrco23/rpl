meta {
  name: Update Data
  type: http
  seq: 3
}

put {
  url: {{base_url}}/fasilitas/:id
  body: json
  auth: bearer
}

params:path {
  id: 1
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "nama_fasilitas": "Laboratorium Komputer (Revisi)",
    "deskripsi": "Deskripsi fasilitas yang diperbarui"
  }
}
