meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/program-unggulan
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_pu: Bootcamp Pemrograman
  deskripsi: Pelatihan coding 12 minggu
  gambar_pu: @file(path/to/mock/image.jpg)
}
