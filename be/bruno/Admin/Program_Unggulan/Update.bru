meta {
  name: Update
  type: http
  seq: 3
}

put {
  url: {{base_url}}/program-unggulan/:id
  body: multipartForm
  auth: bearer
}

params:path {
  id: 1
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_pu: Program Unggulan (Revisi)
  deskripsi: Deskripsi program yang diperbarui
  gambar_pu: @file()
}
