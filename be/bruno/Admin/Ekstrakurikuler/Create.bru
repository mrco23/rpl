meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/ekstrakurikuler
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "nama_ekskul": "Kolintang",
    "p_jwb_ekskul" : "Marco",
    "deskripsi": "example deskripsi"
  }
}

body:multipart-form {
  nama_ekskul: Basket
  deskripsi: Ekstrakurikuler basket untuk siswa putra dan putri
  p_jwb_ekskul: Budi Santoso S.Pd.
  gambar: @file()
}
