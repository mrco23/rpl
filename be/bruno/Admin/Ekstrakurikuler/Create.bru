meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/ekstrakurikuler
  body: multiFormData
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_ekskul: Basket
  deskripsi: Ekstrakurikuler basket untuk siswa putra dan putri
  p_jwb_ekskul: Budi Santoso S.Pd.
  gambar: @file()
}
