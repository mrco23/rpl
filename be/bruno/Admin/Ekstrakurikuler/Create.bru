meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/ekstrakurikuler
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_ekskul: Robotika
  deskripsi: Ekstrakurikuler merakit robot
  p_jwb_ekskul: Pak Budi
  gambar_ekskul: @file(path/to/mock/image.jpg)
}
