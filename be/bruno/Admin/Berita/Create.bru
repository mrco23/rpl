meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/berita
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  judul_berita: Berita Sekolah Terbaru
  deskripsi: Mengadakan acara tahunan
  gambar_berita: @file(path/to/mock/image.jpg)
}
