meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{base_url}}/berita
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "judul_berita": "upacara ",
    "deskripsi" : "Hari ini sekolah melakukan upacara tapi panas"
  }
}

body:multipart-form {
  judul_berita: Berita Baru
  deskripsi: Deskripsi Singkat
  gambar: @file()
}
