meta {
  name: Upsert Profil
  type: http
  seq: 3
}

post {
  url: {{base_url}}/profile
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  nama_sekolah: SMK Hebat
  visi: Visi Unggul
  misi: Misi Cerdas
  nama_kepala_sekolah: Budi
  kata_sambutan: Selamat datang semua
}
